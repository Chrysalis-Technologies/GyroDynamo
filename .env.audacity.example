# Audacity bridge local config (optional)
# Keep this local-only. Do not expose these pipes over a network service.

# Audacity mod-script-pipe defaults on Windows:
AUDACITY_PIPE_TO=\\.\pipe\ToSrvPipe
AUDACITY_PIPE_FROM=\\.\pipe\FromSrvPipe

# End-of-command marker used by Audacity pipe client examples on Windows.
AUDACITY_PIPE_EOL=\r\n\0

# Timeouts/retry tuning for brittle scripting sessions.
AUDACITY_PIPE_CONNECT_TIMEOUT_S=6
AUDACITY_PIPE_RESPONSE_TIMEOUT_S=30
AUDACITY_PIPE_COMMAND_RETRIES=1
AUDACITY_PIPE_RETRY_DELAY_S=0.25
AUDACITY_BRIDGE_LOG_LEVEL=INFO
